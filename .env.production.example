STUDY_ENVIRONMENT=production
STUDY_DEFAULT_USERNAME=admin
STUDY_DEFAULT_PASSWORD=change-this-private-password
STUDY_ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
STUDY_ACCESS_TOKEN_TTL_MINUTES=1440
STUDY_MAX_UPLOAD_BYTES=52428800
STUDY_LOGIN_RATE_LIMIT_PER_MINUTE=5
STUDY_AI_RATE_LIMIT_PER_MINUTE=30
STUDY_CORS_ORIGINS=["http://localhost:5173"]

STUDY_DEEPSEEK_API_KEY=
STUDY_DEEPSEEK_BASE_URL=https://api.deepseek.com
STUDY_DEEPSEEK_MODEL=deepseek-v4-flash

STUDY_EMBEDDING_PROVIDER=hash
STUDY_EMBEDDING_DIMENSIONS=384
STUDY_EMBEDDING_API_KEY=
STUDY_EMBEDDING_BASE_URL=https://api.openai.com/v1
STUDY_EMBEDDING_MODEL=text-embedding-3-small

STUDY_UPLOAD_DIR=/data/uploads
STUDY_POSTGRES_DB=study
STUDY_POSTGRES_USER=study
STUDY_POSTGRES_PASSWORD=change-this-postgres-password
STUDY_DATABASE_URL=postgresql+psycopg://study:change-this-postgres-password@postgres:5432/study
